# Pumplo client env — PUBLIC values only.
# The anon/publishable key is safe to expose; it is protected by Supabase RLS.
# NEVER put service_role keys, Stripe/Resend/FCM secrets, or the Supabase access
# token here — those live in Vercel/Supabase project env vars only.
VITE_SUPABASE_PROJECT_ID=your-project-ref
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-publishable-key
